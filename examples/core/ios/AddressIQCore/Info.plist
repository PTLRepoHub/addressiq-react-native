	<key>NSLocationAlwaysUsageDescription</key>
	<string>AddressIQ verifies your address by confirming your device is at the location over the verification window (2-7 days).</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>
