# AddressIQ React Native SDK — local development overrides.
#
#   cp .env.example .env      # .env is gitignored; put real values there
#
# HOW RN CONSUMES THESE IS DIFFERENT from the other SDKs. React Native ships
# SOURCE and has no build step of its own — which is exactly why
# src/generated/buildConfig.ts is committed. In a bare RN app `process.env.X` is
# simply undefined at runtime, so the SDK cannot read this file for you.
#
# The HOST APP supplies the values, from its own env, one of two ways:
#
#   1. Pass them to initialize() — the reliable path, works everywhere:
#
#        import Config from 'react-native-config';   // or your dotenv setup
#        initialize({
#          apiKey: Config.ADDRESSIQ_API_KEY,
#          deployment: 'development',
#          devApiUrl: Config.ADDRESSIQ_DEV_API_URL,
#          devIngestUrl: Config.ADDRESSIQ_DEV_INGEST_URL,
#          devCdnUrl: Config.ADDRESSIQ_DEV_CDN_URL,
#        });
#
#   2. Let your bundler inline process.env (Expo, or
#      babel-plugin-transform-inline-environment-variables). The SDK reads
#      process.env.ADDRESSIQ_DEV_* when it is defined.
#
# EVERY value here is DEVELOPMENT-ONLY. The SDK honours them solely under
# `deployment: 'development'` and THROWS on a staging or production build, even if
# set. A build-time value must never be able to point a shipped app at an
# arbitrary host.

# ── Hosts ────────────────────────────────────────────────────────────────────
# Default is a compiled-in literal: 10.0.2.2:4000 on Android, localhost:4000 on
# iOS. 10.0.2.2 is an EMULATOR alias for your machine — a PHYSICAL DEVICE cannot
# reach it. Use your LAN IP (`ipconfig getifaddr en0`), and make sure your backend
# binds 0.0.0.0 rather than 127.0.0.1.
#
# On Android, plain HTTP to a LAN IP also needs cleartext permitted in the DEBUG
# manifest (android:usesCleartextTraffic="true"). Debug only.
ADDRESSIQ_DEV_API_URL=http://192.168.1.5:4000
ADDRESSIQ_DEV_INGEST_URL=http://192.168.1.5:4000
ADDRESSIQ_DEV_CDN_URL=http://192.168.1.5:5173
