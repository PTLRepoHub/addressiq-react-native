node_modules/
dist/
*.tsbuildinfo
.turbo/
*.log
.expo/
examples/*/package-lock.json
# Android/iOS build artifacts (the SDK's native source under android/ & ios/ is tracked)
android/build/
android/.gradle/
ios/build/

# ── Local development environment ────────────────────────────────────────────
# Real values (LAN IPs, a local Google Maps key, session tokens) live in .env and
# are NEVER committed. .env.example is the documented template and IS tracked.
# These are development-only overrides: the SDK refuses to honour them on a
# staging or production build.
.env
.env.*
!.env.example
