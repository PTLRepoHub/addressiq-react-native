{
  "name": "@addressiq/react-native",
  "version": "0.1.0",
  "description": "AddressIQ core React Native SDK (bare workflow — no Expo dependency). Address collect + verify lifecycle. Also usable from Expo apps via a dev build.",
  "publishConfig": {
    "access": "public"
  },
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "android",
    "ios",
    "react-native.config.js",
    "AddressIQLocation.podspec",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "example:core": "npm --prefix examples/core install && npm --prefix examples/core run type-check",
    "example:expo": "npm --prefix examples/expo install && npm --prefix examples/expo start"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "@react-native-async-storage/async-storage": ">=1.21.0"
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.45",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "codegenConfig": {
    "name": "AddressIQLocationSpec",
    "type": "modules",
    "jsSrcsDir": "src/native/spec",
    "android": {
      "javaPackageName": "com.addressiq.location"
    }
  },
  "keywords": [
    "react-native",
    "address-verification",
    "location",
    "geolocation",
    "kyc",
    "fraud-detection"
  ]
}
